<group name="windows,process_creation,">
  <rule id="100202" level="10">
    <if_group>windows,sysmon,</if_group>
    <field name="win.eventdata.parentImage">(?i).*\\(winword|excel|outlook)\.exe$</field>
    <field name="win.eventdata.image">(?i).*\\(powershell|cmd)\.exe$</field>
    <description>Office parent spawned shell process</description>
    <mitre>
      <id>T1204.002</id>
      <id>T1059</id>
    </mitre>
    <group>execution,parent_child,</group>
  </rule>
</group>

